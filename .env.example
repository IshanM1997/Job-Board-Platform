# ===========================================
# Job Board Platform - Environment Variables
# Copy this file to .env and fill in real values.
# Never commit your real .env file.
# ===========================================

# Django core
SECRET_KEY=replace-this-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (defaults to SQLite if left blank — fine for local dev)
DATABASE_URL=sqlite:///db.sqlite3

# Email (django signals send notifications through this backend)
# For local development, EMAIL_BACKEND below prints emails to the console
# instead of actually sending them — no SMTP credentials required to run
# the project out of the box.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your_smtp_password_or_api_key
DEFAULT_FROM_EMAIL=noreply@jobboard.example.com

# File uploads
MAX_RESUME_UPLOAD_SIZE_MB=5
